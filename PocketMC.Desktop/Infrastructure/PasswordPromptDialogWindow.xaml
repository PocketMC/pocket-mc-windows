<ui:FluentWindow x:Class="PocketMC.Desktop.Infrastructure.PasswordPromptDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{Binding ElementName=TxtTitle, Path=Text}"
        Width="420"
        SizeToContent="Height"
        MinWidth="360" MaxWidth="520"
        MinHeight="0"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowCornerPreference="Round"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="None"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid MaxWidth="480">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Setup Password" ShowMaximize="False" ShowMinimize="False" />

        <Grid Grid.Row="1" Margin="24,8,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: icon + title -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                <ui:SymbolIcon Symbol="ShieldKeyhole24"
                               FontSize="24"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <TextBlock x:Name="TxtTitle"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- Message body -->
            <TextBlock Grid.Row="1" x:Name="TxtMessage"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       FontSize="13"
                       TextWrapping="Wrap"
                       LineHeight="20"
                       Margin="0,0,0,16"/>

            <ui:PasswordBox Grid.Row="2" x:Name="PwdInput"
                            PlaceholderText="Enter new password"
                            KeyDown="PwdInput_KeyDown"/>

            <!-- Action buttons -->
            <WrapPanel Grid.Row="3" HorizontalAlignment="Right" Margin="0,18,0,0">
                <ui:Button x:Name="BtnCancel"
                           Content="Turn off password"
                           MinWidth="80"
                           Margin="0,0,8,0"
                           Click="BtnCancel_Click"/>

                <ui:Button x:Name="BtnPrimary"
                           Content="Set Password"
                           Appearance="Primary"
                           MinWidth="90"
                           Click="BtnPrimary_Click"
                           IsDefault="True"/>
            </WrapPanel>

        </Grid>
    </Grid>
</ui:FluentWindow>
