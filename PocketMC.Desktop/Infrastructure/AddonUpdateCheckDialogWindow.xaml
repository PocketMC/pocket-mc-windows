<ui:FluentWindow x:Class="PocketMC.Desktop.Infrastructure.AddonUpdateCheckDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Checking for Updates"
        Width="560"
        SizeToContent="Height"
        MinWidth="480" MaxWidth="640"
        MinHeight="0" MaxHeight="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowCornerPreference="Round"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="None"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        Loaded="Window_Loaded">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="VisibleIfTrue"/>
    </ui:FluentWindow.Resources>

    <Grid Margin="20" MaxWidth="600">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <ui:SymbolIcon x:Name="TxtHeaderIcon" Symbol="ArrowSync24" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="#89B4FA"/>
            <TextBlock x:Name="TxtTitle" Text="Scanning for Updates..."
                       FontSize="16" FontWeight="Bold"
                       Foreground="#89B4FA"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Summary text -->
        <TextBlock Grid.Row="1" x:Name="TxtSummary"
                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Margin="0,0,0,10" TextWrapping="Wrap"/>

        <!-- Update items list -->
        <Border Grid.Row="2" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="6" Padding="0"
                MaxHeight="360">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ItemsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8" BorderThickness="0,0,0,1"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Name -->
                                    <TextBlock Grid.Column="1" Grid.Row="0" Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               VerticalAlignment="Center"/>

                                    <!-- Status text -->
                                    <TextBlock Grid.Column="1" Grid.Row="1"
                                               Text="{Binding StatusText}" FontSize="11"
                                               Foreground="{Binding StatusForeground}"
                                               Margin="0,2,0,0"/>

                                    <!-- Indeterminate Progress bar -->
                                    <ProgressBar Grid.Column="1" Grid.Row="2"
                                                 IsIndeterminate="{Binding IsChecking}"
                                                 Height="4" Margin="0,4,0,0"
                                                 Foreground="#89B4FA"
                                                 Visibility="{Binding IsChecking, Converter={StaticResource VisibleIfTrue}}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Overall progress -->
        <StackPanel Grid.Row="3" Margin="0,10,0,0">
            <TextBlock x:Name="TxtOverallStatus" FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Visibility="Visible"/>
            <ProgressBar x:Name="OverallProgressBar"
                         Height="4" Margin="0,4,0,0"
                         Minimum="0" Maximum="100"
                         Foreground="#A6E3A1"
                         Visibility="Visible"/>
        </StackPanel>

        <!-- Buttons -->
        <WrapPanel Grid.Row="4" HorizontalAlignment="Right" Margin="0,14,0,0">
            <ui:Button x:Name="BtnCancel" Content="Cancel"
                       MinWidth="80" Margin="0,0,8,0"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Click="BtnCancel_Click"/>
            <ui:Button x:Name="BtnProceed" Content="Proceed to Updates"
                       Appearance="Primary" MinWidth="140"
                       Foreground="White" FontWeight="SemiBold"
                       Click="BtnProceed_Click" IsDefault="True"
                       Visibility="Collapsed"/>
        </WrapPanel>
    </Grid>
</ui:FluentWindow>
