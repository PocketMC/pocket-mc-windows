<ui:FluentWindow x:Class="PocketMC.Desktop.Features.Marketplace.CurseForgeApiKeyDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{Binding ElementName=TxtTitle, Path=Text}"
        Width="420"
        SizeToContent="Height"
        MinWidth="360" MaxWidth="520"
        MinHeight="0"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowCornerPreference="Round"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="None"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid MaxWidth="480">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="CurseForge API Key" ShowMaximize="False" ShowMinimize="False" />

        <Grid Grid.Row="1" Margin="24,8,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: icon + title -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                <ui:SymbolIcon Symbol="Key24"
                               FontSize="24"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               Foreground="#F9E2AF"/>
                <TextBlock x:Name="TxtTitle"
                           Text="CurseForge API Key Required"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- Message body -->
            <TextBlock Grid.Row="1"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       FontSize="13"
                       TextWrapping="Wrap"
                       LineHeight="20"
                       Margin="0,0,0,16">
                To download or search for CurseForge mods, you need a CurseForge API Key.
                <LineBreak/>
                <Run Text="You can obtain a free key from the "/>
                <Hyperlink NavigateUri="https://console.curseforge.com/#/api-keys/" RequestNavigate="Hyperlink_RequestNavigate">
                    <Run Text="CurseForge Console"/>
                </Hyperlink>
                <Run Text="."/>
            </TextBlock>

            <!-- Input -->
            <ui:TextBox Grid.Row="2" x:Name="TxtApiKey"
                        PlaceholderText="Enter your CurseForge API Key (e.g. $2a$10$xyz...)"
                        Margin="0,0,0,4" />

            <!-- Error Msg -->
            <TextBlock Grid.Row="3" x:Name="TxtError" Foreground="#F38BA8" FontSize="12"
                       Margin="0,0,0,0" Visibility="Collapsed"
                       Text="Please enter a valid API key."/>

            <!-- Action buttons -->
            <WrapPanel Grid.Row="4" HorizontalAlignment="Right" Margin="0,18,0,0">
                <ui:Button Content="Cancel"
                           MinWidth="80"
                           Margin="0,0,8,0"
                           Click="BtnCancel_Click"/>

                <ui:Button Content="Save &amp; Continue"
                           Appearance="Primary"
                           MinWidth="90"
                           Click="BtnSave_Click"
                           IsDefault="True"/>
            </WrapPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
