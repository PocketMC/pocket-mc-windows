<ui:FluentWindow x:Class="PocketMC.Desktop.Features.Tunnel.PlayitSetupWizardDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Connect Playit Agent"
        Width="700" Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowCornerPreference="Round" ExtendsContentIntoTitleBar="True"
        WindowBackdropType="None" Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="🌐 Connect Playit Agent"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
        </StackPanel>

        <!-- Wizard Content -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Step Indicator -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <Border x:Name="StepDot1" Width="32" Height="32" CornerRadius="16"
                        Background="{DynamicResource SystemAccentColorPrimaryBrush}" Margin="0,0,6,0">
                    <TextBlock Text="1" Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}" FontWeight="Bold" FontSize="16"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Width="28" Height="2" Background="{DynamicResource ControlFillColorDefaultBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Border x:Name="StepDot2" Width="32" Height="32" CornerRadius="16"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                    <TextBlock Text="2" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontWeight="Bold" FontSize="16"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- Step Title -->
            <TextBlock x:Name="TxtStepTitle" Grid.Row="1"
                       Text="Get your Setup Code"
                       FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Margin="0,0,0,16"/>

            <!-- Step Content Area -->
            <Grid Grid.Row="2" MinHeight="140">
                <!-- Step 1: Open setup page + choose "Other" -->
                <StackPanel x:Name="Step1Panel" Visibility="Visible">
                    <TextBlock TextWrapping="Wrap" FontSize="15" Margin="0,0,0,14"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                        <Run Text="Click the button below to open the Playit.gg setup page in your browser."/>
                    </TextBlock>
                    
                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap" FontSize="15" Margin="0,0,0,8"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                <Run Text="1. In the browser, select the dropdown menu and choose"/>
                                <Run Text=" &quot;Other&quot;" FontWeight="Bold" Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                                <Run Text="."/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" FontSize="15" Margin="0,0,0,8"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                <Run Text="2. Click"/>
                                <Run Text=" &quot;Next&quot;" FontWeight="Bold" Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                                <Run Text=" in the Playit dashboard."/>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" FontSize="15" Margin="0,0,0,4"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                <Run Text="3. Playit will show you a"/>
                                <Run Text=" setup code" FontWeight="Bold" Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                                <Run Text=" (e.g. gentle-horse-123)."/>
                                <Run Text=" Copy that code!" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <ui:Button Content="Open Setup Page"
                               Icon="{ui:SymbolIcon Globe24}"
                               Appearance="Primary"
                               Cursor="Hand"
                               Click="BtnOpenSetupPage_Click"/>
                </StackPanel>

                <!-- Step 2: Paste setup code and connect -->
                <StackPanel x:Name="Step2Panel" Visibility="Collapsed">
                    <TextBlock TextWrapping="Wrap" FontSize="15" Margin="0,0,0,14"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="Paste the setup code you copied from Playit and click Connect."/>

                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox x:Name="TxtWizardSetupCode"
                                     Grid.Column="0"
                                     Padding="10,8"
                                     TextWrapping="NoWrap"
                                     ToolTip="Paste the Playit setup code here."
                                     VerticalAlignment="Center"/>
                            <ui:Button x:Name="BtnWizardConnect"
                                       Grid.Column="1"
                                       Content="Connect"
                                       Icon="{ui:SymbolIcon PlugConnected24}"
                                       Appearance="Primary"
                                       Cursor="Hand"
                                       Margin="8,0,0,0"
                                       Click="BtnWizardConnect_Click"/>
                        </Grid>
                    </Border>

                    <!-- Status messages -->
                    <TextBlock x:Name="TxtConnectStatus"
                               TextWrapping="Wrap" FontSize="13"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Visibility="Collapsed"/>

                    <!-- Connecting spinner -->
                    <StackPanel x:Name="ConnectingPanel" Orientation="Horizontal"
                                Margin="0,8,0,0" Visibility="Collapsed">
                        <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16"
                                         Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtConnectingStatus"
                                   Text="Connecting..."
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Navigation / Footer Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <ui:Button Content="Cancel"
                       Appearance="Secondary"
                       Cursor="Hand"
                       Margin="0,0,8,0"
                       Click="BtnCancel_Click"/>
            <ui:Button x:Name="BtnPrevStep"
                       Content="Previous"
                       Icon="{ui:SymbolIcon ArrowLeft24}"
                       Appearance="Secondary"
                       Cursor="Hand"
                       Margin="0,0,8,0"
                       Visibility="Collapsed"
                       Click="BtnPrevStep_Click"/>
            <ui:Button x:Name="BtnNextStep"
                       Content="Next"
                       Icon="{ui:SymbolIcon ArrowRight24}"
                       Appearance="Primary"
                       Cursor="Hand"
                       Click="BtnNextStep_Click"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
